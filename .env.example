# --- Anthropic (required for chat / log analysis features) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- AWS (add this and/or the GCP block below - at least one is required
# for `status` / `check-alarms`) ---
# Set AWS_PROFILE, or both AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_PROFILE=
# Set to 1/true if you're relying on an attached IAM instance role instead
# of the above (can't be auto-detected, so this is an explicit opt-in).
AWS_USE_INSTANCE_ROLE=

# --- GCP (add this and/or the AWS block above - at least one is required
# for `status` / `check-alarms`) ---
# GCP_PROJECT_ID must be set for GCP checks to run. Auth can come from
# Application Default Credentials (`gcloud auth application-default login`)
# or a service account key below.
GCP_PROJECT_ID=
# Path to a service account JSON key file. If blank, ADC is used
# (gcloud CLI login, or the metadata server on GCE/GKE/Cloud Run).
GOOGLE_APPLICATION_CREDENTIALS=
# Comma-separated list of GCE zones to scan for instances, e.g. us-central1-a,us-east1-b
GCP_ZONES=us-central1-a

# --- Optional: Slack alerting ---
SLACK_WEBHOOK_URL=

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
