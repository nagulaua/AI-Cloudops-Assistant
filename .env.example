# --- Anthropic (required for chat / log analysis features) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- AWS (required for cloud status / monitoring features) ---
# Leave these blank to use your default AWS CLI credentials/profile instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_PROFILE=

# --- GCP (required for GCP status / monitoring features) ---
# Leave blank to skip GCP checks entirely, or to use Application Default
# Credentials (e.g. `gcloud auth application-default login`) instead.
GCP_PROJECT_ID=
# Path to a service account JSON key file. If blank, ADC is used
# (gcloud CLI login, or the metadata server on GCE/GKE/Cloud Run).
GOOGLE_APPLICATION_CREDENTIALS=
# Comma-separated list of GCE zones to scan for instances, e.g. us-central1-a,us-east1-b
GCP_ZONES=us-central1-a

# --- Optional: Slack alerting ---
SLACK_WEBHOOK_URL=

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
